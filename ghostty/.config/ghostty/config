font-family =
font-size =

# thickens the font, but only minimally
font-thicken = true
font-thicken-strength = 0

# disable ligatures
font-feature= -calt

theme = dark:wez,light:apple system colors light

# minimum-contrast = 1.1

# extends program bg color to window edges
window-padding-color = extend

macos-titlebar-style = transparent
macos-auto-secure-input = true
macos-secure-input-indication = true
macos-icon =
macos-option-as-alt = true
window-height = 32
window-width = 120
cursor-style =
adjust-cursor-thickness = 125%
shell-integration-features = no-cursor, sudo, ssh-env
mouse-hide-while-typing = true
background-opacity =
scrollback-limit = 20000

bell-features = no-attention

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
